{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aequicor/Workout/utils/workout_plan.schema.json",
  "title": "Workout Plan Artifact Input",
  "type": "object",
  "required": ["title", "workouts"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "client": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" }
      }
    },
    "overview": { "$ref": "#/$defs/stringOrStringArray" },
    "assumptions": { "$ref": "#/$defs/stringOrStringArray" },
    "safety_notes": { "$ref": "#/$defs/stringOrStringArray" },
    "progression_rules": { "$ref": "#/$defs/stringOrStringArray" },
    "substitution_rules": { "$ref": "#/$defs/stringOrStringArray" },
    "cooldown": { "$ref": "#/$defs/stringOrStringArray" },
    "check_in": { "$ref": "#/$defs/stringOrStringArray" },
    "schedule": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "week": { "type": ["integer", "string"] },
          "day": { "type": "string" },
          "focus": { "type": "string" },
          "duration": { "type": "string" }
        }
      }
    },
    "workouts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["exercises"],
        "additionalProperties": true,
        "properties": {
          "week": { "type": ["integer", "string"] },
          "day": { "type": "string" },
          "focus": { "type": "string" },
          "exercises": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["exercise"],
              "additionalProperties": true,
              "properties": {
                "block": { "type": "string" },
                "exercise": { "type": "string", "minLength": 1 },
                "visual_source": {
                  "type": "string",
                  "format": "uri"
                },
                "sets_reps": { "type": "string" },
                "intensity": { "type": "string" },
                "rest": { "type": "string" },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "stringOrStringArray": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "type": "string" }
        }
      ]
    }
  }
}
